{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/assets/**",
          "!/assets/sirena-alerta.png",
          "!/assets/sirena-alerta.webp",
          "/*.(png|jpg|jpeg|webp|avif|svg)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "firestore-api",
      "urls": [
        "https://firestore.googleapis.com/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "10m",
        "timeout": "3s"
      }
    },
    {
      "name": "firebase-storage-images",
      "urls": [
        "https://firebasestorage.googleapis.com/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 80,
        "maxAge": "7d",
        "timeout": "5s"
      }
    }
  ]
}
